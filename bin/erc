#!/usr/bin/env python3
import os
import sys
import tempfile
import subprocess

if len(sys.argv) < 2:
    print("usage: erc <file.kicad_sch>", file=sys.stderr)
    sys.exit(1)

sch = sys.argv[1]
path = "/Applications/KiCad/KiCad.app/Contents/MacOS:" + os.environ.get("PATH", "")

with tempfile.NamedTemporaryFile(prefix="kicad-erc.", suffix=".json", delete=False) as tmp:
    tmp_path = tmp.name

try:
    result = subprocess.run(
        ["kicad-cli", "sch", "erc", sch, "--format", "json", "--output", tmp_path],
        env={**os.environ, "PATH": path},
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    if result.returncode != 0:
        print("erc: kicad-cli failed", file=sys.stderr)
        sys.exit(1)

    with open(tmp_path, "rb") as f:
        try:
            sys.stdout.buffer.write(f.read())
        except BrokenPipeError:
            pass
finally:
    os.unlink(tmp_path)
